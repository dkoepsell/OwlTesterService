# Copy this file to .env and fill in the values

# Flask session encryption — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# OpenAI API key for implication generation and AI suggestions
OPENAI_API_KEY=

# PostgreSQL credentials (used by both the db service and the app)
POSTGRES_USER=owltester
POSTGRES_PASSWORD=
POSTGRES_DB=owl_tester

# Constructed from the above — do not change unless running an external DB
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Optional: path to a custom BFO OWL file inside the container
# BFO_PATH=/app/bfo.owl
