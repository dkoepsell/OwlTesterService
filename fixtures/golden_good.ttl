@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix obo:  <http://purl.obolibrary.org/obo/> .
@prefix sool: <https://seal.tamu.edu/sool/kernel#> .
@prefix ex:   <https://seal.tamu.edu/sool/cases/golden#> .

# Golden-good fixture: a small kernel-conformant case fragment. MUST pass A-E.
# Every class grounds to a BFO anchor through a SOoL category; failure is modelled
# as a typology *instance*, never a named class.

<https://seal.tamu.edu/sool/cases/golden> a owl:Ontology .

### Classes, each under a SOoL kernel category. -------------------------------

ex:PaymentNorm           a owl:Class ; rdfs:label "Payment Norm" ;       rdfs:subClassOf sool:Norm .
ex:SignContractObligation a owl:Class ; rdfs:label "Sign Contract Obligation" ; rdfs:subClassOf sool:Obligation .
ex:ContractValidity      a owl:Class ; rdfs:label "Contract Validity" ;  rdfs:subClassOf sool:LegalEffect .
ex:DriverRole            a owl:Class ; rdfs:label "Driver Role" ;        rdfs:subClassOf sool:Role .
ex:PersonAgent           a owl:Class ; rdfs:label "Person Agent" ;       rdfs:subClassOf sool:Agent .
ex:SigningEvent          a owl:Class ; rdfs:label "Signing Event" ;      rdfs:subClassOf sool:LegalEvent .
ex:ContractDispute       a owl:Class ; rdfs:label "Contract Dispute" ;   rdfs:subClassOf sool:Contradiction .

### Object property with domain/range and an assertion (satisfies A3). ---------

ex:realizedByAgent a owl:ObjectProperty ;
    rdfs:label "realized by agent" ;
    rdfs:domain ex:DriverRole ;
    rdfs:range  ex:PersonAgent .

### Individuals and assertions. -----------------------------------------------

ex:alice       a ex:PersonAgent .
ex:aliceDriver a ex:DriverRole ; ex:realizedByAgent ex:alice .

# Failure modelled as an instance of a contradiction typology class, not a class.
ex:disputeOverSignature a ex:ContractDispute .
