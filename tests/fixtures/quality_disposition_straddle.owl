<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/aero#"
     xml:base="http://example.org/aero"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:obo="http://purl.obolibrary.org/obo/">
    <owl:Ontology rdf:about="http://example.org/aero"/>

    <!-- Reference the two BFO categories so they are recognized as classes. -->
    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000016"/>

    <!-- Force straddles Quality (BFO_0000019) and Disposition (BFO_0000016),
         which are disjoint in BFO 2020. Exactly one straddle. -->
    <owl:Class rdf:about="http://example.org/aero#Force">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label>Force</rdfs:label>
    </owl:Class>
</rdf:RDF>
